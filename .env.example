# 이름은 PUBLIC_APP_BASE_URL 이지만, 현재 프론트 코드에서는 "API base URL" 로 사용합니다.
# 프론트 도메인이 아니라 백엔드 API 주소를 넣어야 합니다.
# 현재 권장 예시: https://api.jamissue.growgardens.app
PUBLIC_APP_BASE_URL=https://api.jamissue.growgardens.app
PUBLIC_NAVER_MAP_CLIENT_ID=YOUR_NAVER_MAP_CLIENT_ID
# or
# NAVER_MAP_CLIENT_ID=YOUR_NAVER_MAP_CLIENT_ID