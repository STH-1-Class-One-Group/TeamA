# Cloudflare Worker local dev only
# 이 파일을 `.dev.vars` 로 복사해서 로컬 Worker 테스트에 사용하세요.
# 절대 저장소에 커밋하지 마세요.
# 운영 예시 기준:
# - 프론트: https://jamissue.growgardens.app
# - API: https://api.jamissue.growgardens.app

APP_ENV=worker
APP_SESSION_HTTPS=true
APP_FRONTEND_URL=https://jamissue.growgardens.app
APP_CORS_ORIGINS=https://jamissue.growgardens.app
APP_NAVER_LOGIN_CALLBACK_URL=https://api.jamissue.growgardens.app/api/auth/naver/callback
APP_STORAGE_BACKEND=supabase
APP_STAMP_UNLOCK_RADIUS_METERS=120
APP_SUPABASE_URL=https://your-project-ref.supabase.co
APP_SUPABASE_STORAGE_BUCKET=review-images

# Secret 성격의 값들
APP_SESSION_SECRET=CHANGE_ME_SESSION_SECRET
APP_JWT_SECRET=CHANGE_ME_JWT_SECRET
APP_DATABASE_URL=postgres://postgres.your-project-ref:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
APP_SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_SUPABASE_SERVICE_ROLE_KEY
APP_NAVER_LOGIN_CLIENT_ID=CHANGE_ME_NAVER_LOGIN_CLIENT_ID
APP_NAVER_LOGIN_CLIENT_SECRET=CHANGE_ME_NAVER_LOGIN_CLIENT_SECRET

# 선택값
APP_ADMIN_USER_IDS=
APP_SUPABASE_ANON_KEY=
APP_SUPABASE_STORAGE_PUBLIC_BASE_URL=
APP_GOOGLE_LOGIN_CLIENT_ID=
APP_GOOGLE_LOGIN_CLIENT_SECRET=
APP_KAKAO_LOGIN_CLIENT_ID=
APP_KAKAO_LOGIN_CLIENT_SECRET=
APP_APPLE_LOGIN_CLIENT_ID=
APP_APPLE_LOGIN_CLIENT_SECRET=