APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8001
APP_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
APP_FRONTEND_URL=http://localhost:8000
APP_SESSION_SECRET=CHANGE_ME_LOCAL_SESSION_SECRET
APP_SESSION_HTTPS=false
APP_JWT_SECRET=CHANGE_ME_LOCAL_JWT_SECRET
APP_JWT_ACCESS_TOKEN_MINUTES=20160
APP_ADMIN_USER_IDS=
# 로컬 기본값은 MySQL 예시입니다.
# Worker / 서버리스 배포에서는 Supabase transaction pooler(보통 6543 포트) URL을 권장합니다.
# 예시: APP_DATABASE_URL=postgres://postgres.<project-ref>:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
APP_DATABASE_URL=mysql+pymysql://jamissue:jamissue@127.0.0.1:3306/jamissue?charset=utf8mb4
APP_SEED_DEMO_DATA=false
APP_CLEANUP_LEGACY_DEMO_DATA=true
APP_AUTO_IMPORT_PUBLIC_DATA=true
APP_PUBLIC_DATA_PATH=data/public_bundle.json
APP_PUBLIC_DATA_SOURCE_URL=
APP_STORAGE_BACKEND=local
APP_UPLOAD_DIR=storage/uploads
APP_UPLOAD_BASE_URL=/uploads
APP_MAX_UPLOAD_SIZE_BYTES=5242880
APP_SUPABASE_URL=
APP_SUPABASE_ANON_KEY=
APP_SUPABASE_SERVICE_ROLE_KEY=
APP_SUPABASE_STORAGE_BUCKET=review-images
APP_SUPABASE_STORAGE_PUBLIC_BASE_URL=
APP_NAVER_LOGIN_CLIENT_ID=YOUR_NAVER_LOGIN_CLIENT_ID
APP_NAVER_LOGIN_CLIENT_SECRET=YOUR_NAVER_LOGIN_CLIENT_SECRET
APP_NAVER_LOGIN_CALLBACK_URL=http://localhost:8000/api/auth/naver/callback
APP_GOOGLE_LOGIN_CLIENT_ID=
APP_GOOGLE_LOGIN_CLIENT_SECRET=
APP_KAKAO_LOGIN_CLIENT_ID=
APP_KAKAO_LOGIN_CLIENT_SECRET=
APP_APPLE_LOGIN_CLIENT_ID=
APP_APPLE_LOGIN_CLIENT_SECRET=
APP_STAMP_UNLOCK_RADIUS_METERS=120
