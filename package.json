{
  "name": "jamissue",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "node scripts/build-frontend.mjs",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:regression": "vitest run test/regression",
    "test:smoke:ui": "vitest run test/smoke",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:regression && npm run test:smoke:ui",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/run-smoke-checks.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "24.10.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.1",
    "typescript": "5.6.3",
    "vitest": "^4.1.2"
  }
}
